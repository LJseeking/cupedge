{
  "name": "cupedge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:push:prod": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:seed:prod": "prisma db seed --schema prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "update:site": "node --import tsx scripts/update-data.ts",
    "update:home": "node --import tsx scripts/update-home.ts",
    "update:data": "node --import tsx scripts/update-data.ts",
    "update:ratings": "node --import tsx scripts/update-ratings.ts",
    "probe:polymarket": "node --import tsx scripts/probe-polymarket.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.4",
    "postcss": "^8.4.49",
    "prisma": "^6.10.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  }
}
